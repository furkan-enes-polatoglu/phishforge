# ---- PhishForge configuration ----
# Copy to .env and edit. NEVER commit the real .env (it is gitignored).

# Mode is set per-container by docker-compose (api|worker|migrate); leave default here.
PHISHFORGE_ENV=production

# --- Secrets (REQUIRED) ---
# Generate strong random values, e.g.:  openssl rand -hex 32
JWT_SECRET=change-me-to-a-32-byte-random-hex
RID_SECRET=change-me-to-another-32-byte-random-hex

# --- Database / cache ---
# For docker-compose these are overridden to reach the postgres/redis services.
POSTGRES_USER=phishforge
POSTGRES_PASSWORD=phishforge
POSTGRES_DB=phishforge
DATABASE_URL=postgres://phishforge:phishforge@postgres:5432/phishforge?sslmode=disable
REDIS_URL=redis://redis:6379/0

# --- HTTP ---
ADMIN_ADDR=:8080
PHISH_ADDR=:8081
ADMIN_PORT=8080
PHISH_PORT=8081
# Public base URLs used in tracking links & CORS. Set PHISH_BASE_URL to the host
# targets will actually reach (behind your reverse proxy / phishing domain).
ADMIN_BASE_URL=http://localhost:8080
PHISH_BASE_URL=http://localhost:8081
CORS_ORIGINS=http://localhost:5173,http://localhost:8080

# --- Auth token lifetimes ---
ACCESS_TTL_MIN=30
REFRESH_TTL_HOURS=168

# --- First-run admin (created only if there are no users yet) ---
BOOTSTRAP_ORG_NAME=My Security Firm
BOOTSTRAP_ADMIN_USERNAME=admin
BOOTSTRAP_ADMIN_PASSWORD=change-me-strong-password

# --- Worker ---
WORKER_CONCURRENCY=4

# --- Deliverability (optional) ---
# host:port of a SpamAssassin spamd instance for spam scoring. Empty = disabled.
SPAMD_ADDR=
